PORT=4000
MONGODB_URI=mongodb+srv://macallingm_db_user:Mahar12345@cmpt315.wjujc6s.mongodb.net/cmpt315?retryWrites=true&w=majority&appName=CMPT31
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173

# Same key as frontend VITE_TMDB_API_KEY — import catalog via Admin → Library
TMDB_API_KEY=5c844d989576e4be6bde742e7e9fe910

# Optional: return OTP in API JSON for local testing only (never enable in production)
# OTP_DEV_ECHO=true

# --- Sign-in codes (email + SMS) ---------------------------------------------
# Users request a code on Sign in → "Use a sign-in code".
# • Email: must match the email on their StreamLab account → code sent via SMTP.
# • Phone: must match the phone stored on their account → code sent via Twilio SMS.

# SMTP (email OTP) — one server account sends codes to every user’s registered email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password-or-app-password
# Inbox display name (default StreamLab)
EMAIL_FROM_NAME=StreamLab
# Address recipients see. Leave empty to use SMTP_USER (Gmail will show your Gmail).
# To avoid showing a personal Gmail, use SendGrid/Mailgun and a verified noreply@yourdomain.com
EMAIL_FROM_ADDRESS=
# Optional: full From header; if set, overrides NAME + ADDRESS above
# EMAIL_FROM="StreamLab <noreply@yourdomain.com>"

# Twilio (SMS OTP) — use Auth Token below OR API Key SID + Secret (not both needed for auth)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Optional alternative to TWILIO_AUTH_TOKEN:
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=your_api_key_secret

# Set ONE of: a Messaging Service SID, or a verified From number
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=+15551234567

# --- Admin bootstrap (runs at server startup) --------------------------------
ADMIN_BOOTSTRAP_EMAIL=admin@streamlab.ca
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_BOOTSTRAP_NAME=StreamLab Admin

# Optional seed (Windows: set VAR=value then npm run seed)
# SEED_DEMO_USER=true
# SEED_DEMO_EMAIL=demo@example.com
# SEED_DEMO_PASSWORD=password123
# SEED_ADMIN_EMAIL=manager@example.com
# SEED_ADMIN_PASSWORD=changeme

# --- Password reset (Forgot password on Sign in) ------------------------------
# Uses the same SMTP settings as sign-in codes. Reset links are built from
# CLIENT_ORIGIN (e.g. http://localhost:5173) + /reset-password?token=...
# If SMTP is not configured, the API logs the one-time link to the server terminal.
