PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/streamlab
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173

# Same key as frontend VITE_TMDB_API_KEY — used to import catalog titles into MongoDB
TMDB_API_KEY=your_tmdb_api_key_here
# Optional: return OTP code in API response for local testing only
# OTP_DEV_ECHO=true

# Twilio SMS OTP (for /api/auth/otp/request with phone numbers)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15551234567
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Group admin bootstrap (created/updated at server startup)
# ADMIN_BOOTSTRAP_EMAIL=admin@streamlab.ca
# ADMIN_BOOTSTRAP_PASSWORD=change-this-admin-password
# ADMIN_BOOTSTRAP_NAME=StreamLab Admin

# Optional seed (Windows: set VAR=value then npm run seed)
# SEED_DEMO_USER=true
# SEED_DEMO_EMAIL=macallingm@mymacewan.ca
# SEED_DEMO_PASSWORD=password123
# SEED_ADMIN_EMAIL=manager@example.com
# SEED_ADMIN_PASSWORD=changeme
